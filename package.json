{
  "name": "scrapping-tool",
  "version": "1.0.0",
  "description": "Express app powered by Polaris automation",
  "private": true,
  "scripts": {
    "dev": "npm run build:packages && nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "start": "node dist/index.js",
    "build": "npm run build:packages && tsc",
    "build:packages": "npm run build:polaris && npm run build:visawise",
    "build:polaris": "cd packages/polaris && npm run build",
    "build:visawise": "cd packages/visawise && npm run build",
    "seed:countries": "ts-node scripts/seed-countries.ts",
    "seed:destination-countries": "ts-node scripts/seed-destination-countries.ts",
    "seed": "npm run seed:countries && npm run seed:destination-countries",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo",
    "db:migrate:undo:all": "sequelize-cli db:migrate:undo:all"
  },
  "dependencies": {
    "@polaris/core": "file:./packages/polaris",
    "@visawise/core": "file:./packages/visawise",
    "bullmq": "^5.76.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.17",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "nodemon": "^3.1.14",
    "sequelize-cli": "^6.6.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
